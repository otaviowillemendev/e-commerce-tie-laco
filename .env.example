# ============================================================
# Tie Laços — variáveis de ambiente Shopify
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA suba o .env para o GitHub.
# ============================================================

# Domínio da sua loja Shopify
# Exemplo: tie-lacos.myshopify.com
VITE_SHOPIFY_DOMAIN=sua-loja.myshopify.com

# Token da Storefront API (somente leitura — seguro no frontend)
# Onde obter: Admin Shopify → Configurações → Apps → Desenvolver apps
#             → Criar app → Configuração da API → Storefront API → Gerar token
VITE_SHOPIFY_STOREFRONT_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Versão da API (mantenha esta, atualize só quando necessário)
VITE_SHOPIFY_API_VERSION=2025-01
